#!/usr/bin/env python3
"""
获取有效的 access_token。
AK/SK 从与 chanjing-config 相同的配置文件中读取（CONFIG_DIR/credentials.json）。
若无 AK/SK，则提示用户先配置本地凭证；若 Token 过期或失效，则自动重新申请并保存。
用法: chanjing-get-token
输出: 成功时打印 access_token 到 stdout；失败时打印错误到 stderr 并 exit 1
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _auth import get_token


def main():
    token, err = get_token()
    if err:
        print(err, file=sys.stderr)
        sys.exit(1)
    print(token)


if __name__ == "__main__":
    main()